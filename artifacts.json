{
  "version": "0.1.0",
  "categories": [
    {
      "id": "vm",
      "name": "Virtual Machine",
      "description": "VMware, VirtualBox, and QEMU registry artifacts. Most commodity malware bails immediately when it sees these.",
      "artifacts": [
        { "type": "registry_key", "path": "HKLM\\SOFTWARE\\VMware, Inc." },
        { "type": "registry_key", "path": "HKLM\\SOFTWARE\\VMware, Inc.\\VMware Tools" },
        { "type": "registry_key", "path": "HKLM\\SOFTWARE\\Oracle\\VirtualBox Guest Additions" },
        { "type": "registry_key", "path": "HKLM\\HARDWARE\\ACPI\\DSDT\\VBOX__" },
        { "type": "registry_key", "path": "HKLM\\HARDWARE\\ACPI\\FADT\\VBOX__" },
        { "type": "registry_key", "path": "HKLM\\HARDWARE\\ACPI\\RSDT\\VBOX__" },
        { "type": "registry_key", "path": "HKLM\\SYSTEM\\ControlSet001\\Services\\VBoxGuest" },
        { "type": "registry_key", "path": "HKLM\\SYSTEM\\ControlSet001\\Services\\VBoxMouse" },
        { "type": "registry_key", "path": "HKLM\\SYSTEM\\ControlSet001\\Services\\VBoxService" },
        { "type": "registry_key", "path": "HKLM\\SYSTEM\\ControlSet001\\Services\\VBoxSF" },
        { "type": "registry_key", "path": "HKLM\\SYSTEM\\ControlSet001\\Services\\VBoxVideo" }
      ]
    },
    {
      "id": "antivirus",
      "name": "Antivirus",
      "description": "Registry keys that make it look like common AV products are installed.",
